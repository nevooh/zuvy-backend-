# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_HOST=localhost
DB_DATABASE=school_os
DB_PASSWORD=your_password_here
DB_PORT=5432
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_64_byte_random_hex_string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS (comma-separated; required in production) ────────────────────────────
ALLOWED_ORIGINS=https://admin.yourschool.com,https://app.yourschool.com

# ── Africa's Talking (SMS) ────────────────────────────────────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox

# ── M-Pesa ────────────────────────────────────────────────────────────────────
# Use https://sandbox.safaricom.co.ke for dev, https://api.safaricom.co.ke for production
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_STK_SHORTCODE=your_stk_shortcode
MPESA_B2B_SHORTCODE=your_b2b_shortcode
MPESA_PASSKEY=your_passkey
MPESA_INITIATOR_NAME=your_initiator_name
MPESA_SECURITY_CREDENTIAL=your_security_credential
MPESA_CALLBACK_URL=https://your-domain.com/api/parent/finance/mpesa-callback
BASE_URL=https://your-domain.com

# ── Cloudinary (media uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
